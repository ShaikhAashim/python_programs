<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <title>Pizza Shop</title>
</head>
<body>
    <form action="#" method="post">
        <fieldset>
        <div class="container">
            <h2>Customer Detail</h2>
            <div class="mb-3 row">
                <label for="name" class="col-2 col-form-label">Name:</label>
                <div class="col-10 mb-3">
                    <input type="text" class="form-control" id="name" name="name" placeholder="Enter Your Name" required>
                </div>
                <label for="phone" class="col-2 col-form-label">Mobile Number:</label>
                <div class="col-10 mb-3">
                    <input type="tel" class="form-control" id="phone" name="phone" placeholder="Enter Your Phone Number" required>
                </div>
                <label for="address" class="col-2 col-form-label">Address:</label>
                <div class="col-10 mb-3">
                    <textarea class="form-control" id="address" name="address" rows="3" placeholder="Enter Your Address" required></textarea>
                </div>
                <h2>Pizza Topping Detail</h3>

                <div class="col-3 mb-3 form-check-label">Pizza Type:</div>
                <div class="col-3 mb-3">
                    <input type="checkbox" id="supreme" name="supreme" class="form-check-input">
                    <label for="supreme" class="form-check-label">supreme</label>
                </div>
                <div class="col-3 mb-3">
                    <label class="form-check-label">Quentity:</label>
                </div>
                <div class="col-3 mb-3">
                    <input type="number" class="form-control" name="Q1">
                </div>

                <div class="col-3 mb-3"></div>
                <div class="col-3 mb-3">
                    <input type="checkbox" id="cheese" name="cheese" class="form-check-input">
                    <label for="cheese" class="form-check-label">cheese</label>
                </div>
                <div class="col-3 mb-3">
                    <label class="form-check-label">Quentity:</label>
                </div>
                <div class="col-3 mb-3">
                    <input type="number" class="form-control" name="Q1">
                </div>

                <div class="col-3 mb-3"></div>
                <div class="col-3 mb-3">
                    <input type="checkbox" id="veg" name="veg" class="form-check-input">
                    <label for="veg" class="form-check-label">veg</label>
                </div>
                <div class="col-3 mb-3">
                    <label class="form-check-label">Quentity:</label>
                </div>
                <div class="col-3 mb-3">
                    <input type="number" class="form-control" name="Q1">
                </div>

            
                <label class="col-form-label col-2">Pizza Size:</label>
                <input type="radio" id="s" name="size" class="form-check-input col-1" >
                <label class="form-check-input" for="s">Small</label>
                <input type="radio" id="m" name="size" class="form-check-input col-1" >
                <label class="form-check-input" for="m">Medium</label>
                <input type="radio" id="l" name="size" class="form-check-input col-1" >
                <label class="form-check-input" for="l">Large</label>

            </div>
        
        </div>
        </fieldset>
    </form>
</body>
</html>
